PORT=4000
CORS_ORIGIN=http://localhost:8080,http://localhost:8081,http://localhost:5173,http://127.0.0.1:5173
# Optional: Public backend origin used in generated file links (important for cluster/proxy deploys)
# PUBLIC_BASE_URL=https://api.yourdomain.com
# MONGO_URI=mongodb://localhost:27017/aselea_db

# Optional: Cloudinary for resume uploads (if omitted, files stay in local uploads/)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
# CLOUDINARY_FOLDER=aselea-resumes
